# Hyperliquid ETL Pipeline .gitignore

# Data directories
data/raw_blocks/*
data/converted/*
data/logs/*
data/dlq/*
!data/raw_blocks/.gitkeep
!data/converted/.gitkeep
!data/logs/.gitkeep
!data/dlq/.gitkeep

# Terraform files
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/terraform.tfstate*
terraform/terraform.tfvars
terraform/crash.log
terraform/override.tf
terraform/override.tf.json
terraform/*_override.tf
terraform/*_override.tf.json
terraform/.terraformrc
terraform/terraform.rc

# AWS credentials and config
.aws/
aws.config
credentials

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
pipenv/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
*.log
logs/
log/

# Temporary files
*.tmp
*.temp
tmp/
temp/

# Configuration files with secrets
configs/*local*
configs/*secret*
configs/*private*
.env.local
.env.production
.env.staging

# StarRocks
starrocks/
be.conf.local
fe.conf.local

# Backup files
*.bak
*.backup
*.old

# Processing files
*.processing
*.lock
*.pid

# Cache
.cache/
cache/

# Documentation build
docs/_build/
site/

# Test files
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.hypothesis/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# Security
*.pem
*.key
*.crt
*.p12
secrets.yaml
secrets.json

# Local development
docker-compose.override.yml
.local/

# Monitoring and metrics
metrics/
prometheus/
grafana/

# Archives
*.zip
*.tar.gz
*.tar.bz2
*.rar
*.7z

# Large data files
*.parquet
*.csv.gz
*.json.gz
*.avro

# Node modules (if any frontend tools)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Database
*.db
*.sqlite
*.sqlite3

# Configuration overrides
config.local.*
settings.local.* 

data*